{
  "entities": {
    "User": {
      "title": "User",
      "description": "System participant",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["USER", "ADMIN", "ADD_ADMIN", "MONITOR"] },
        "warningLevel": { "type": "number" },
        "debtOwed": { "type": "number" },
        "debtToMe": { "type": "number" },
        "ratingAverage": { "type": "number" },
        "ratingCount": { "type": "number" },
        "totalLendingTransactions": { "type": "number" },
        "isPermanentlyRemoved": { "type": "boolean" },
        "restrictedUntil": { "type": "string" },
        "communityServicesNeeded": { "type": "number" }
      },
      "required": ["username", "password", "role"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Work exchange record",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "askerId": { "type": "string" },
        "pages": { "type": "number" },
        "debt": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "isCommunityService": { "type": "boolean" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["senderId", "askerId", "pages", "debt", "status", "createdAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Admin posted updates",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["content", "authorId", "timestamp"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "Anonymous submission",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "timestamp": { "type": "string" },
        "reviewedBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["content", "timestamp"]
    },
    "Dispute": {
      "title": "Dispute",
      "description": "Issues and verdicts",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["ONGOING", "RESOLVED"] },
        "verdict": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["description", "status", "date"]
    },
    "GroupPost": {
      "title": "Group Post",
      "description": "Post in a group",
      "type": "object",
      "properties": {
        "groupId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["groupId", "authorId", "content", "timestamp"]
    },
    "RoleConfig": {
      "title": "Role Configuration",
      "description": "Centralized role assignment lists",
      "type": "object",
      "properties": {
        "admins": { "type": "array", "items": { "type": "string" } },
        "monitors": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["admins", "monitors"]
    },
    "SystemStatus": {
      "title": "System Status",
      "description": "Global emergency and state settings",
      "type": "object",
      "properties": {
        "emergencyLevel": { "type": "number", "enum": [1, 2, 3] },
        "updatedBy": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["emergencyLevel", "updatedBy", "timestamp"]
    },
    "Bill": {
      "title": "Bill",
      "description": "Proposed rule or policy",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "proposedBy": { "type": "string" },
        "createdBy": { "type": "string" },
        "priority": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "resolved"] },
        "verdict": { "type": "string" },
        "createdAt": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["title", "category", "description", "proposedBy", "createdBy", "priority", "status", "timestamp"]
    },
    "BillComment": {
      "title": "Bill Comment",
      "description": "Public comment on a bill",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["userId", "message", "timestamp"]
    },
    "BillStaffComment": {
      "title": "Bill Staff Comment",
      "description": "Admin/Monitor only comment on a bill",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["userId", "role", "message", "timestamp"]
    },
    "RoleRequest": {
      "title": "Role Request",
      "description": "Request for high-privilege role",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "requestedRole": { "type": "string", "enum": ["ADMIN", "MONITOR"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string" }
      },
      "required": ["userId", "username", "requestedRole", "status", "timestamp"]
    },
    "ForgivenessLog": {
      "title": "Forgiveness Log",
      "description": "Log of debt forgiveness",
      "type": "object",
      "properties": {
        "forgiverId": { "type": "string" },
        "receiverId": { "type": "string" },
        "debtsForgiven": { "type": "number" },
        "timestamp": { "type": "string" }
      },
      "required": ["forgiverId", "receiverId", "debtsForgiven", "timestamp"]
    },
    "Leaderboard": {
      "title": "Leaderboard",
      "description": "Global leaderboard metrics",
      "type": "object",
      "properties": {
        "communityCarer": {
          "type": "object",
          "properties": {
            "userId": { "type": "string" },
            "username": { "type": "string" },
            "totalContribution": { "type": "number" }
          }
        },
        "updatedAt": { "type": "string" }
      }
    },
    "MonitoringPillar": {
      "title": "Monitoring Pillar",
      "description": "Final bill or case verdict",
      "type": "object",
      "properties": {
        "billId": { "type": "string", "description": "Optional id of original bill" },
        "caseId": { "type": "string", "description": "Optional id of original case" },
        "title": { "type": "string" },
        "verdict": { "type": "string" },
        "caseNumber": { "type": "string" },
        "issuedBy": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["title", "verdict", "issuedBy", "timestamp"]
    },
    "ChatterboxMessage": {
      "title": "Chatterbox Message",
      "description": "A single message in an AI conversation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    },
    "Vote": {
      "title": "Vote",
      "description": "Unified system for elections, polling, and decisions",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Election", "Polling", "Decision", "Confidence Vote"] },
        "options": { "type": "array", "items": { "type": "string" } },
        "isAnonymous": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string" },
        "totalVotes": { "type": "number" },
        "results": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "count": { "type": "number" },
              "users": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "required": ["title", "type", "options", "isAnonymous", "status", "createdBy", "createdAt"]
    },
    "VoteResponse": {
      "title": "Vote Response",
      "description": "A single vote response from a user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "User ID" },
        "selectedOption": { "type": "string" },
        "votedAt": { "type": "string" },
        "username": { "type": "string" }
      },
      "required": ["id", "selectedOption", "votedAt", "username"]
    },
    "NetDebt": {
      "title": "Net Debt",
      "description": "Bilateral balance between two users",
      "type": "object",
      "properties": {
        "user1Id": { "type": "string" },
        "user2Id": { "type": "string" },
        "netBalance": { "type": "number" },
        "updatedAt": { "type": "string" }
      },
      "required": ["user1Id", "user2Id", "netBalance", "updatedAt"]
    },
    "Reward": {
      "title": "Reward",
      "description": "User achievement reward",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "claimed": { "type": "boolean" },
        "rewardChosen": { "type": "string" },
        "timestamp": { "type": "string" },
        "period": { "type": "string" }
      },
      "required": ["userId", "type", "claimed", "timestamp", "period"]
    }
  },
  "firestore": {
    "debts/{id}": {
      "schema": { "$ref": "#/entities/NetDebt" },
      "description": "Collection of bilateral debt balances"
    },
    "rewards/{id}": {
      "schema": { "$ref": "#/entities/Reward" },
      "description": "Collection of user rewards"
    },
    "monitoringPillars/{id}": {
      "schema": { "$ref": "#/entities/MonitoringPillar" },
      "description": "Historical collection of finalized verdicts"
    },
    "votes/{id}": {
      "schema": { "$ref": "#/entities/Vote" },
      "description": "Unified voting system records"
    },
    "votes/{voteId}/responses/{userId}": {
      "schema": { "$ref": "#/entities/VoteResponse" },
      "description": "Individual responses for a vote"
    },
    "forgivenessLogs/{id}": {
      "schema": { "$ref": "#/entities/ForgivenessLog" },
      "description": "Audit trail for debt forgiveness"
    },
    "leaderboard/current": {
      "schema": { "$ref": "#/entities/Leaderboard" },
      "description": "Real-time global leaderboard document"
    },
    "roleRequests/{id}": {
      "schema": { "$ref": "#/entities/RoleRequest" },
      "description": "Collection of role access requests"
    },
    "systemStatus/{id}": {
      "schema": { "$ref": "#/entities/SystemStatus" },
      "description": "Global system status and emergency level"
    },
    "roles_config/{configId}": {
      "schema": { "$ref": "#/entities/RoleConfig" },
      "description": "Global role configuration document"
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of users"
    },
    "transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Collection of work exchange transactions"
    },
    "announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Collection of admin announcements"
    },
    "complaints/{complaintId}": {
      "schema": { "$ref": "#/entities/Complaint" },
      "description": "Collection of anonymous complaints"
    },
    "disputes/{disputeId}": {
      "schema": { "$ref": "#/entities/Dispute" },
      "description": "Collection of resolving issues"
    },
    "groups/{groupId}/posts/{postId}": {
      "schema": { "$ref": "#/entities/GroupPost" },
      "description": "Posts within specific groups"
    },
    "bills/{billId}": {
      "schema": { "$ref": "#/entities/Bill" },
      "description": "Collection of proposed bills"
    },
    "bills/{billId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/BillComment" },
      "description": "Public comments on a bill"
    },
    "bills/{billId}/staffComments/{commentId}": {
      "schema": { "$ref": "#/entities/BillStaffComment" },
      "description": "Internal staff comments on a bill"
    },
    "chatterbox_threads/{userId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatterboxMessage" },
      "description": "Private AI assistant conversations per user"
    }
  }
}
