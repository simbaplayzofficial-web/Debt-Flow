rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Phase 1: Primitive Definitions & Helpers
    // -------------------------------------------------------------------------
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email != null && (
          request.auth.token.email.lower() == 'patty@debtflow.com' ||
          request.auth.token.email.lower() == 'chiti@debtflow.com'
        )) ||
        (exists(/databases/$(database)/documents/roles_config/global) && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username.lower() in get(/databases/$(database)/documents/roles_config/global).data.admins)
      );
    }
    function isMonitor() {
      return isSignedIn() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/roles_config/global) && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username.lower() in get(/databases/$(database)/documents/roles_config/global).data.monitors)
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // -------------------------------------------------------------------------
    // Global Safety Net
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Users Collection
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.username is string && data.username.size() >= 3 && data.username.size() <= 64 &&
             data.warningLevel is number && data.warningLevel >= 0 &&
             data.integrityScore is number && data.integrityScore >= 0 && data.integrityScore <= 100 &&
             data.integrityLevel is number && data.integrityLevel >= 0 && data.integrityLevel <= 5 &&
             data.debtOwed is number && data.debtToMe is number &&
             data.ratingAverage is number && data.ratingCount is number &&
             data.totalLendingTransactions is number &&
             data.isPermanentlyRemoved is bool &&
             data.communityServicesNeeded is number;
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['username', 'ratingAverage', 'ratingCount', 'debtOwed', 'debtToMe', 'totalLendingTransactions', 'communityServicesNeeded'])) ||
        (isMonitor() && incoming().diff(existing()).affectedKeys().hasOnly(['warningLevel', 'integrityLevel', 'integrityScore', 'communityServicesNeeded', 'restrictedUntil', 'isPermanentlyRemoved']))
      );
      allow delete: if isAdmin();

      match /warnings/{warningId} {
        allow read: if isOwner(userId) || isMonitor();
        allow write: if isMonitor();
      }
    }

    match /roles_config/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Transactions
    // -------------------------------------------------------------------------
    function isValidTransaction(data) {
      return data.senderId is string && isValidId(data.senderId) &&
             data.receiverId is string && isValidId(data.receiverId) &&
             data.type in ['lend', 'pay'] &&
             data.workName is string && data.workName.size() <= 200 &&
             data.pages is number && data.pages >= 0 &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'approved', 'rejected', 'completed', 'cancelled'] &&
             data.timestamp is string &&
             data.createdAt == request.time;
    }

    function isUserRestricted(userId) {
      let profile = get(/databases/$(database)/documents/users/$(userId)).data;
      return profile.isPermanentlyRemoved == true || 
             (profile.restrictedUntil != null && timestamp(profile.restrictedUntil) > request.time) ||
             (profile.integrityLevel >= 2 && profile.communityServicesNeeded > 0);
    }

    match /transactions/{txId} {
      allow get: if isSignedIn() && (resource.data.receiverId == request.auth.uid || resource.data.senderId == request.auth.uid || isMonitor());
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && 
                    incoming().senderId == request.auth.uid && 
                    isValidTransaction(incoming()) && 
                    !isUserRestricted(incoming().receiverId);
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isMonitor() && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        ((existing().receiverId == request.auth.uid || existing().senderId == request.auth.uid) && existing().status == 'approved' && incoming().status == 'completed' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'rating'])) ||
        (existing().senderId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['isForgiven']))
      );
    }

    // -------------------------------------------------------------------------
    // Announcements
    // -------------------------------------------------------------------------
    function isValidAnnouncement(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.section in ['GLOBAL', 'MONITORING', 'RESOLVING'] &&
             data.authorId == request.auth.uid &&
             data.timestamp is string;
    }

    match /announcements/{id} {
      allow read: if true;
      allow create: if isSignedIn() && isValidAnnouncement(incoming()) && (
        isAdmin() || 
        (isMonitor() && (incoming().section == 'MONITORING' || incoming().section == 'RESOLVING'))
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Complaints & Disputes
    // -------------------------------------------------------------------------
    match /complaints/{id} {
      allow create: if true; 
      allow read: if isMonitor();
      allow update: if isMonitor();
    }

    // -------------------------------------------------------------------------
    // Resolving Deck & Justice Nexus
    // -------------------------------------------------------------------------
    match /resolvingDeck/{id} {
      allow read: if isSignedIn();
      allow create: if isMonitor();
      allow update: if isMonitor();
    }

    match /justiceNexus/{id} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
    }

    match /systemStatus/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Activity Logs
    // -------------------------------------------------------------------------
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid && 
                    incoming().timestamp == request.time &&
                    incoming().username is string &&
                    incoming().action is string;
      allow update, delete: if false; 
    }

    // -------------------------------------------------------------------------
    // Debt Adjustments (Forgiveness requests)
    // -------------------------------------------------------------------------
    match /debtAdjustments/{adjId} {
      allow create: if isSignedIn() && incoming().lenderId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.borrowerId == request.auth.uid || resource.data.lenderId == request.auth.uid || isMonitor());
      allow update: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Debt Ledger
    // -------------------------------------------------------------------------
    match /debts/{debtId} {
      allow read: if isSignedIn() && (resource.data.user1Id == request.auth.uid || resource.data.user2Id == request.auth.uid || isMonitor());
      allow write: if isSignedIn() && (incoming().user1Id == request.auth.uid || incoming().user2Id == request.auth.uid);
    }

    // -------------------------------------------------------------------------
    // Groups
    // -------------------------------------------------------------------------
    match /groups/{groupId}/posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (groupId != 'monitoring' || isMonitor());
    }

    // -------------------------------------------------------------------------
    // Monitor Deck: Bills & Comments
    // -------------------------------------------------------------------------
    match /bills/{billId} {
      allow read: if isSignedIn();
      allow create: if isMonitor();
      allow update: if isMonitor();
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }

      match /staffComments/{commentId} {
        allow read: if isMonitor();
        allow create: if isMonitor();
      }
    }
  }
}
