rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Phase 1: Primitive Definitions & Helpers
    // -------------------------------------------------------------------------
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    function isMonitor() {
      return isSignedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "monitor"
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isSpyOwner() {
      return isSignedIn() && request.auth.uid == 'K7MRkBbJtdSapnLfw2giwLzmhwA3';
    }
    function hasSpyAccess() {
      return isSpyOwner() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/spyNetwork/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/spyNetwork/$(request.auth.uid)).data.active == true
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // -------------------------------------------------------------------------
    // Global Safety Net
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Users Collection
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.username is string && data.username.size() >= 3 && data.username.size() <= 64 &&
             data.role in ['user', 'monitor', 'admin'] &&
             (!('requestedRole' in data) || data.requestedRole == null || data.requestedRole in ['monitor', 'admin']) &&
             data.status in ['active', 'restricted', 'suspended'] &&
             data.warningCount is number && data.warningCount >= 0 &&
             data.integrityLevel is number && data.integrityLevel >= 0 && data.integrityLevel <= 5 &&
             data.debtOwed is number && data.debtToMe is number &&
             data.ratingAverage is number && data.ratingCount is number &&
             data.totalLendingTransactions is number &&
             data.isPermanentlyRemoved is bool &&
             data.communityServicesNeeded is number;
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth != null && (request.auth.token.role == "admin" || request.auth.token.role == "ADMIN")) ||
        (isOwner(userId) && incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['username', 'requestedRole', 'ratingAverage', 'ratingCount', 'debtOwed', 'debtToMe', 'totalLendingTransactions', 'communityServicesNeeded'])) ||
        (isMonitor() && incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['warningCount', 'integrityLevel', 'integrityScore', 'communityServicesNeeded', 'restrictedUntil', 'isPermanentlyRemoved']))
      );
      allow delete: if isAdmin();

      match /warnings/{warningId} {
        allow read: if isOwner(userId) || isMonitor();
        allow create: if isMonitor();
        allow delete: if isAdmin();
      }
    }

    match /roleRequests/{requestId} {
      allow read: if isAdmin() || isMonitor() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().status == 'pending';
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin();
    }

    match /roles_config/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Transactions
    // -------------------------------------------------------------------------
    function isValidTransaction(data) {
      return data.senderId is string && isValidId(data.senderId) &&
             data.receiverId is string && isValidId(data.receiverId) &&
             data.type in ['lend', 'pay'] &&
             data.workName is string && data.workName.size() <= 200 &&
             data.pages is number && data.pages >= 0 &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'approved', 'rejected', 'completed', 'cancelled'] &&
             data.timestamp is string &&
             data.createdAt == request.time;
    }

    function isUserRestricted(userId) {
      let profile = get(/databases/$(database)/documents/users/$(userId)).data;
      return profile.isPermanentlyRemoved == true || 
             (profile.restrictedUntil != null && timestamp(profile.restrictedUntil) > request.time) ||
             (profile.integrityLevel >= 2 && profile.communityServicesNeeded > 0);
    }

    match /transactions/{txId} {
      allow create, read, update: if request.auth != null;
    }

    // -------------------------------------------------------------------------
    // Announcements
    // -------------------------------------------------------------------------
    function isValidAnnouncement(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.section in ['GLOBAL', 'MONITORING', 'RESOLVING'] &&
             data.authorId == request.auth.uid &&
             data.timestamp is string;
    }

    match /announcements/{id} {
      allow read: if true;
      allow create: if isSignedIn() && isValidAnnouncement(incoming()) && (
        isAdmin() || 
        (isMonitor() && (incoming().section == 'MONITORING' || incoming().section == 'RESOLVING'))
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Complaints & Disputes
    // -------------------------------------------------------------------------
    match /complaints/{id} {
      allow create: if true; 
      allow read: if isMonitor();
      allow update: if isMonitor();
    }

    // -------------------------------------------------------------------------
    // Resolving Deck & Justice Nexus
    // -------------------------------------------------------------------------
    match /resolvingDeck/{id} {
      allow read: if isSignedIn();
      allow create: if isMonitor();
      allow update: if isMonitor();
    }

    match /justiceNexus/{id} {
      allow read: if isSignedIn();
      allow write: if isMonitor();
    }

    // -------------------------------------------------------------------------
    // Global Read-Only Collections (Signed In Users)
    // -------------------------------------------------------------------------
    match /leaderboard/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /forgivenessLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isMonitor();
    }

    match /monitoringPillars/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /systemConfig/warningRules {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /announcements/{id} {
      allow read: if true;
      allow create: if isMonitor();
      allow write: if isAdmin();
    }

    match /systemStatus/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /votes/{voteId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /responses/{userId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    match /rewards/{rewardId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isMonitor());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['claimed', 'rewardChosen', 'timestamp']);
      allow create, delete: if isAdmin();
    }

    match /spyNetwork/{id} {
      allow read: if hasSpyAccess();
      allow write: if isSpyOwner();
    }

    // -------------------------------------------------------------------------
    // Special Operations (RESTRICTED)
    // -------------------------------------------------------------------------
    match /specialAccess/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || hasSpyAccess());
      allow write: if isSpyOwner() || hasSpyAccess();
    }

    match /specialOpsLogs/{logId} {
      allow read: if hasSpyAccess();
      allow create: if hasSpyAccess() && incoming().userId == request.auth.uid;
    }

    match /internalNotes/{noteId} {
      allow read: if hasSpyAccess();
      allow create: if hasSpyAccess();
    }

    match /recruitments/{recId} {
      allow read: if hasSpyAccess();
      allow write: if hasSpyAccess();
    }

    // -------------------------------------------------------------------------
    // Activity Logs
    // -------------------------------------------------------------------------
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && 
                    (incoming().userId == request.auth.uid || incoming().actor == request.auth.uid) && 
                    incoming().timestamp == request.time &&
                    incoming().action is string;
      allow update, delete: if false; 
    }

    // -------------------------------------------------------------------------
    // Debt Adjustments (Forgiveness requests)
    // -------------------------------------------------------------------------
    match /debtAdjustments/{adjId} {
      allow create: if isSignedIn() && incoming().lenderId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.borrowerId == request.auth.uid || resource.data.lenderId == request.auth.uid || isMonitor());
      allow update: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Debt Ledger
    // -------------------------------------------------------------------------
    match /debts/{debtId} {
      allow read: if isSignedIn() && (resource.data.user1Id == request.auth.uid || resource.data.user2Id == request.auth.uid || isMonitor());
      allow write: if isMonitor() || (isSignedIn() && (incoming().user1Id == request.auth.uid || incoming().user2Id == request.auth.uid));
    }

    // -------------------------------------------------------------------------
    // Groups
    // -------------------------------------------------------------------------
    match /groups/{groupId}/posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (groupId != 'monitoring' || isMonitor());
    }

    // -------------------------------------------------------------------------
    // Monitor Deck: Bills & Comments
    // -------------------------------------------------------------------------
    match /bills/{billId} {
      allow read: if isSignedIn();
      allow create: if isMonitor();
      allow update: if isMonitor();
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }

      match /staffComments/{commentId} {
        allow read: if isMonitor();
        allow create: if isMonitor();
      }
    }

    // -------------------------------------------------------------------------
    // Votes & Elections
    // -------------------------------------------------------------------------
    match /votes/{voteId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /responses/{userId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId) && get(/databases/$(database)/documents/votes/$(voteId)).data.status == 'active';
        allow update, delete: if false;
      }
    }

    match /elections/{electionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /parties/{partyId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      match /votes/{userId} {
        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/elections/$(electionId)).data.status == 'declared');
        allow get: if isOwner(userId) || (isSignedIn() && get(/databases/$(database)/documents/elections/$(electionId)).data.status == 'declared');
        allow create: if isOwner(userId) && get(/databases/$(database)/documents/elections/$(electionId)).data.status == 'open';
        allow update, delete: if false;
      }
    }

    // -------------------------------------------------------------------------
    // Leaderboard & Forgiveness
    // -------------------------------------------------------------------------
    match /leaderboard/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /forgivenessLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isMonitor();
    }

    // -------------------------------------------------------------------------
    // Chatterbox AI Threads
    // -------------------------------------------------------------------------
    match /chatterbox_threads/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
