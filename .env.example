# GEMINI_API_KEY: Required for Chatterbox (AI Hub).
# For full-stack apps, the server uses GEMINI_API_KEY.
# For pure frontend apps, use VITE_GEMINI_API_KEY.
# Chatterbox handles both.
GEMINI_API_KEY="YOUR_KEY_HERE"
VITE_GEMINI_API_KEY="YOUR_KEY_HERE"

# APP_URL: Platform automatically injects this.
APP_URL="http://localhost:3000"
